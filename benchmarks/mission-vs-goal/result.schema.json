{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "mission vs goal benchmark result",
  "type": "object",
  "required": [
    "benchmark",
    "run_id",
    "task_id",
    "arm",
    "model",
    "started_at",
    "completed_at",
    "starting_commit",
    "completion",
    "validator_pass",
    "human_quality_score",
    "quality_score_method",
    "intervention_count",
    "evidence_completeness",
    "elapsed_minutes",
    "artifacts",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "benchmark": {
      "const": "mission-vs-goal-pilot"
    },
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "arm": {
            "enum": [
                "goal_only",
                "claude_code_goal_command",
                "mission"
            ]
    },
    "model": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "starting_commit": {
      "type": "string",
      "minLength": 7
    },
    "run_status": {
      "enum": [
        "completed",
        "failed",
        "blocked"
      ]
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "api_usage_limit",
        "timeout",
        null
      ]
    },
    "failure_kind": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "api_usage_limit",
        "timeout",
        "validator",
        "command_error",
        "missing_artifact",
        null
      ]
    },
    "comparable_attempt": {
      "type": "boolean"
    },
    "completion": {
      "type": "boolean"
    },
    "validator_pass": {
      "type": "boolean"
    },
    "human_quality_score": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "quality_score_method": {
      "enum": [
        "blind_human",
        "label_hidden_human",
        "automated_heuristic_not_blind_human"
      ]
    },
    "intervention_count": {
      "type": "integer",
      "minimum": 0
    },
    "resume_success": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "evidence_completeness": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "elapsed_minutes": {
      "type": "number",
      "minimum": 0
    },
    "token_estimate": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
